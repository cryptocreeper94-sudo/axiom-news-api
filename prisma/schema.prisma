generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Article {
  id              String   @id @default(uuid())
  publisherId     String
  source          String
  timestamp       DateTime
  coreEvent       String
  processTimeline String[]
  biasScore       Int
  originalText    String
  strippedTerms   String[]
  isSatire        Boolean  @default(false)
  category        String?  @default("World")
  image           String?
  deterministicRewrite String?
  author          String?
  trustCertificate String?
  sourceProofHash  String?
  createdAt       DateTime @default(now())

  @@index([publisherId])
  @@index([timestamp])
}

model TrafficLog {
  id        String   @id @default(uuid())
  path      String
  ip        String?
  userAgent String?
  timestamp DateTime @default(now())

  @@index([path])
  @@index([timestamp])
}

model BlogPost {
  id                   String   @id @default(uuid())
  title                String
  originalDraft        String
  deterministicRewrite String
  trustCertificate     String
  sourceProofHash      String?
  publishedAt          DateTime @default(now())
}

model Subscriber {
  id        String   @id @default(uuid())
  email     String?  @unique
  phone     String?  @unique
  createdAt DateTime @default(now())
  active    Boolean  @default(true)
}
