generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Article {
  id              String   @id @default(uuid())
  publisherId     String
  source          String
  timestamp       DateTime
  coreEvent       String
  processTimeline String[]
  biasScore       Int
  originalText    String
  strippedTerms   String[]
  isSatire        Boolean  @default(false)
  category        String?  @default("World")
  image           String?
  deterministicRewrite String?
  createdAt       DateTime @default(now())

  @@index([publisherId])
  @@index([timestamp])
}
